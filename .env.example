# ─────────────────────────────────────────────────────────────
# ensage — environment variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────
PORT=3000

# ── Security (REQUIRED — change before deploying!) ──────────
# Used to sign HMAC access tokens. Must be a long random string.
TOKEN_SECRET=change-me-to-a-long-random-secret-string

# ── Storage paths (local/self-hosted only) ──────────────────
# Where uploaded files are stored on disk.
# UPLOAD_DIR=./uploads

# Where the SQLite database file lives.
# DB_PATH=./db/ensage.db

# ── Upload limits ────────────────────────────────────────────
# Maximum file upload size in bytes. Default: 500 MB.
# MAX_FILE_SIZE=524288000

# Maximum text paste size in bytes. Default: 5 MB.
# MAX_TEXT_SIZE=5242880

# ── UI customization ─────────────────────────────────────────
# Accent color for the interface (hex only). Default: #22c55e
# ACCENT_COLOR=#22c55e

# ── Rate limits (requests per minute per IP) ─────────────────
# RATE_LIMIT_UPLOAD=10
# RATE_LIMIT_READ=100
# RATE_LIMIT_AUTH=20

# ── Optional: AI summaries (Exa API) ─────────────────────────
# Provide your Exa API key to enable AI summaries for shared links.
# EXA_API_KEY=

# ── Optional: PostgreSQL (instead of SQLite) ─────────────────
# If set, PostgreSQL is used instead of SQLite.
# POSTGRES_URL=postgres://user:password@localhost:5432/ensage
# DATABASE_URL=postgres://user:password@localhost:5432/ensage

# ── Optional: Vercel Blob (instead of local filesystem) ──────
# If set, files are stored in Vercel Blob instead of the local disk.
# BLOB_READ_WRITE_TOKEN=

# ── Optional: Node environment ───────────────────────────────
NODE_ENV=production
